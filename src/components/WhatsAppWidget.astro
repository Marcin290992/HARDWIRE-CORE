<style>
#wa-widget {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 9000;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12px;
}

#wa-popup {
  display: none;
  flex-direction: column;
  width: 300px;
  background: var(--bg);
  border: 1px solid var(--red-border);
  clip-path: var(--clip-cut);
  overflow: hidden;
}

#wa-popup.is-open {
  display: flex;
}

.wa-popup__redline {
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--red), transparent);
  flex-shrink: 0;
}

.wa-popup__header {
  background: var(--bg3);
  padding: 0.75rem 1rem;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 1px solid var(--border);
}

.wa-popup__avatar {
  width: 32px;
  height: 32px;
  clip-path: var(--clip-cut);
  background: rgba(220, 38, 38, 0.12);
  border: 1px solid var(--red-border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.wa-popup__info {
  display: flex;
  flex-direction: column;
  gap: 2px;
  flex: 1;
  min-width: 0;
}

.wa-popup__name {
  font-family: var(--font-head);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text);
}

.wa-popup__status {
  font-family: var(--font-mono);
  font-size: 9px;
  color: var(--red);
  letter-spacing: 0.06em;
}

.wa-popup__close {
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.3);
  cursor: pointer;
  font-size: 16px;
  padding: 0;
  line-height: 1;
  flex-shrink: 0;
  transition: color 0.2s;
}

.wa-popup__close:hover {
  color: var(--red);
}

.wa-popup__body {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.wa-popup__bubble {
  background: rgba(220, 38, 38, 0.05);
  border: 1px solid var(--red-border);
  padding: 0.65rem 0.85rem;
  font-family: var(--font-body);
  font-size: 12px;
  line-height: 1.6;
  color: var(--text-mid);
}

.wa-popup__textarea {
  width: 100%;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid var(--border);
  color: var(--text);
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 0.65rem;
  resize: none;
  outline: none;
  line-height: 1.6;
  transition: border-color 0.2s;
}

.wa-popup__textarea:focus {
  border-color: var(--red-border);
}

.wa-popup__send {
  width: 100%;
  height: 42px;
  background: var(--red);
  border: none;
  color: #fff;
  font-family: var(--font-head);
  font-size: 9px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  clip-path: var(--clip-cut);
  transition: opacity 0.2s;
}

.wa-popup__send:hover {
  opacity: 0.85;
}

.wa-fab {
  width: 52px;
  height: 52px;
  clip-path: var(--clip-cut);
  background: var(--red);
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s, transform 0.2s;
  box-shadow: 0 4px 20px rgba(220, 38, 38, 0.35);
}

.wa-fab:hover {
  opacity: 0.85;
  transform: scale(1.05);
}

@media (max-width: 480px) {
  #wa-widget {
    bottom: 16px;
    right: 16px;
  }

  #wa-popup {
    width: calc(100vw - 32px);
    max-width: 300px;
  }

  .wa-fab {
    width: 46px;
    height: 46px;
  }
}
</style>

<script>
  function initWaWidget() {
    const fab = document.getElementById('waFab');
    const popup = document.getElementById('wa-popup');
    const closeBtn = document.getElementById('waClose');
    const sendBtn = document.getElementById('waSend');
    const msgInput = document.getElementById('waMsg');

    if (!fab || !popup) return;

    fab.addEventListener('click', () => {
      popup.classList.toggle('is-open');
    });

    closeBtn?.addEventListener('click', () => {
      popup.classList.remove('is-open');
    });

    sendBtn?.addEventListener('click', () => {
      const msg = (msgInput as HTMLTextAreaElement)?.value?.trim();
      const text = msg || "Hi, I'd like to get a repair quote.";
      window.open('https://wa.me/447575701219?text=' + encodeURIComponent(text), '_blank');
    });
  }

  document.addEventListener('astro:page-load', initWaWidget);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') document.getElementById('wa-popup')?.classList.remove('is-open');
  });
</script>
