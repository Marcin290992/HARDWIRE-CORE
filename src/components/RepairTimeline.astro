---
const repairs = [
  { id: 'keyboard', time: '20', unit: 'min', label: 'Keyboard Replacement', icon: 'keyboard' },
  { id: 'screen', time: '45', unit: 'min', label: 'Screen Replacement', icon: 'monitor' },
  { id: 'cleaning', time: '60', unit: 'min', label: 'Deep Clean & Thermal Paste', icon: 'wind' },
  { id: 'os', time: '90', unit: 'min', label: 'OS Reinstallation', icon: 'code' },
  { id: 'virus', time: '2', unit: 'hrs', label: 'Virus & Malware Removal', icon: 'shield' },
  { id: 'data', time: '1-3', unit: 'days', label: 'Data Recovery', icon: 'database' },
];

const icons = {
  keyboard: '<rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 10h.01M10 10h.01M14 10h.01M18 10h.01M6 14h12"/>',
  monitor: '<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
  wind: '<path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  database: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/>',
};
---

<section class="rtl" id="repair-timeline" aria-label="Repair turnaround timeline">
  <div class="rtl__topline" aria-hidden="true"></div>

  <div class="rtl__inner">
    <header class="rtl__header">
      <span class="rtl__eyebrow">// Turnaround times</span>
      <h2>How long does it take?</h2>
      <p>Most repairs are same day. Complex jobs get a realistic estimate upfront.</p>
    </header>

    <div class="rtl__track" data-rtl-track>
      <div class="rtl__line" aria-hidden="true"></div>
      <div class="rtl__line-fill" data-rtl-fill aria-hidden="true"></div>

      {repairs.map((repair, idx) => (
        <div class="rtl__node" data-rtl-node style={`--rtl-delay: ${idx * 120}ms;`} tabindex="0" aria-label={`${repair.label} takes around ${repair.time} ${repair.unit}`}>
          <span class="rtl__dot" aria-hidden="true"></span>

          <div class="rtl__content">
            <div class="rtl__time">
              <span class="rtl__time-num">{repair.time}</span>
              <span class="rtl__time-unit">{repair.unit}</span>
            </div>
            <p class="rtl__label">{repair.label}</p>
          </div>

          <div class="rtl__tooltip" role="tooltip">
            <div class="rtl__tooltip-head">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[repair.icon as keyof typeof icons]}></svg>
              <span>{repair.label}</span>
            </div>
            <div class="rtl__tooltip-time">~ {repair.time} {repair.unit}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="rtl__bottomline" aria-hidden="true"></div>
</section>

<style>
.rtl {
  position: relative;
  background:
    radial-gradient(ellipse 80% 50% at 50% 50%, rgba(220,38,38,0.08) 0%, transparent 70%),
    radial-gradient(ellipse 50% 40% at 20% 80%, rgba(220,38,38,0.04) 0%, transparent 60%),
    var(--bg);
  overflow: hidden;
}

.rtl::after {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.025;
  background-image:
    linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
  background-size: 60px 60px;
}

.rtl::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 0, 0, 0.12) 2px,
    rgba(0, 0, 0, 0.12) 4px
  );
  pointer-events: none;
  z-index: 0;
}

.rtl > * {
  position: relative;
  z-index: 1;
}

.rtl__topline {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(220, 38, 38, 0.5), transparent);
}

.rtl__bottomline {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent);
}

.rtl__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 4rem 2.5rem 5rem;
}

.rtl__header {
  margin-bottom: 3rem;
}

.rtl__eyebrow {
  display: block;
  margin-bottom: 1rem;
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--red);
  text-shadow: 0 0 16px rgba(220, 38, 38, 0.35);
}

.rtl__header h2 {
  margin-bottom: 0.5rem;
  font-family: var(--font-head);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--text);
}

.rtl__header p {
  font-family: var(--font-body);
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--text-muted);
}

.rtl__track {
  position: relative;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-top: 60px;
}

.rtl__line,
.rtl__line-fill {
  position: absolute;
  top: 20px;
  left: 0;
  right: 0;
  height: 1px;
}

.rtl__line {
  background: linear-gradient(90deg, transparent, var(--border2) 10%, var(--border2) 90%, transparent);
}

.rtl__line-fill {
  right: auto;
  width: 0;
  background: linear-gradient(90deg, var(--red-dark), var(--red));
  transition: width 1.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.rtl__track.is-visible .rtl__line-fill {
  width: 100%;
}

.rtl__node {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  cursor: pointer;
}

.rtl__dot {
  width: 14px;
  height: 14px;
  background: var(--bg3);
  border: 2px solid var(--border2);
  position: relative;
  z-index: 2;
  transition: border-color 0.2s var(--ease), background 0.2s var(--ease), transform 0.2s var(--ease);
}

.rtl__node:hover .rtl__dot,
.rtl__node:focus-visible .rtl__dot,
.rtl__node:focus-within .rtl__dot {
  border-color: var(--red);
  background: var(--red);
  transform: scale(1.4);
  box-shadow: 0 0 16px rgba(220, 38, 38, 0.4);
}

.rtl__content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rtl__time {
  margin-top: 16px;
  text-align: center;
}

.rtl__time-num {
  display: block;
  font-family: var(--font-head);
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  color: var(--text);
  line-height: 1;
  text-shadow: 0 0 20px rgba(255, 255, 255, 0.06);
  transition: text-shadow 0.3s;
}

.rtl__node:hover .rtl__time-num {
  text-shadow: 0 0 24px rgba(220,38,38,0.25);
}

.rtl__time-unit {
  display: block;
  margin-top: 2px;
  font-family: var(--font-mono);
  font-size: 8px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.rtl__label {
  margin-top: 8px;
  text-align: center;
  max-width: 90px;
  font-family: var(--font-body);
  font-size: 11px;
  line-height: 1.4;
  color: var(--text-muted);
}

.rtl__tooltip {
  position: absolute;
  bottom: calc(100% + 28px);
  left: 50%;
  transform: translateX(-50%) translateY(6px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s var(--ease), transform 0.2s var(--ease);
  background: rgba(8, 8, 8, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--red-border);
  clip-path: var(--clip-cut);
  padding: 0.65rem 0.85rem;
  white-space: nowrap;
  z-index: 20;
  box-shadow: 0 0 24px rgba(220, 38, 38, 0.1);
}

.rtl__tooltip::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 6px solid transparent;
  border-right: 6px solid transparent;
  border-top: 6px solid var(--red-border);
}

.rtl__node:hover .rtl__tooltip,
.rtl__node:focus-visible .rtl__tooltip,
.rtl__node:focus-within .rtl__tooltip {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

.rtl__tooltip-head {
  display: flex;
  align-items: center;
  gap: 8px;
}

.rtl__tooltip-head svg {
  width: 16px;
  height: 16px;
  color: var(--red);
  flex-shrink: 0;
}

.rtl__tooltip-head span {
  font-family: var(--font-head);
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text);
}

.rtl__tooltip-time {
  margin-top: 0.45rem;
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--red);
}

.rtl__track[data-rtl-ready='true'] .rtl__node {
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 0.45s var(--ease) var(--rtl-delay), transform 0.45s var(--ease) var(--rtl-delay);
}

.rtl__track.is-visible .rtl__node {
  opacity: 1;
  transform: translateY(0);
}

.rtl__node:focus-visible {
  outline: 1px solid var(--red);
  outline-offset: 6px;
}

@media (max-width: 1024px) {
  .rtl__inner {
    padding: 4rem 1.5rem 4.5rem;
  }
}

@media (max-width: 768px) {
  .rtl__track {
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    padding-top: 0;
    padding-left: 40px;
  }

  .rtl__line,
  .rtl__line-fill {
    top: 0;
    bottom: 0;
    left: 20px;
    right: auto;
    width: 1px;
    height: auto;
  }

  .rtl__line {
    background: linear-gradient(180deg, transparent, var(--border2) 10%, var(--border2) 90%, transparent);
  }

  .rtl__line-fill {
    width: 1px;
    height: 0;
    background: linear-gradient(180deg, var(--red-dark), var(--red));
    transition: height 1.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .rtl__track.is-visible .rtl__line-fill {
    width: 1px;
    height: 100%;
  }

  .rtl__node {
    flex-direction: row;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .rtl__content {
    align-items: flex-start;
  }

  .rtl__time {
    margin-top: 0;
    text-align: left;
  }

  .rtl__time-num {
    font-size: clamp(1.25rem, 7vw, 1.6rem);
  }

  .rtl__label {
    max-width: none;
    text-align: left;
    font-size: 12px;
  }

  .rtl__tooltip {
    display: none;
  }
}

@media (prefers-reduced-motion: reduce) {
  .rtl__line-fill,
  .rtl__track[data-rtl-ready='true'] .rtl__node {
    transition: none;
  }

  .rtl__track[data-rtl-ready='true'] .rtl__node {
    transform: none;
  }
}
</style>

<script>
  const initRepairTimeline = () => {
    const track = document.querySelector<HTMLElement>('[data-rtl-track]');
    if (!track) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    track.classList.remove('is-visible');
    track.removeAttribute('data-rtl-ready');

    if (reduceMotion) {
      track.classList.add('is-visible');
      return;
    }

    track.setAttribute('data-rtl-ready', 'true');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          track.classList.add('is-visible');
          observer.disconnect();
        });
      },
      {
        threshold: 0.35,
      }
    );

    observer.observe(track);
  };

  const runRepairTimeline = () => {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => initRepairTimeline());
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runRepairTimeline, { once: true });
  } else {
    runRepairTimeline();
  }

  document.addEventListener('astro:page-load', runRepairTimeline);
  document.addEventListener('astro:after-swap', runRepairTimeline);
</script>