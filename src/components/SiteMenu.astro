---
import ContactModal from './ContactModal.astro';
const bookingUrl = 'https://wa.me/447575701219?text=Hi%2C%20I%27d%20like%20to%20book%20a%20repair.';
const contactUrl = 'https://wa.me/447575701219';
---

<div class="topbar" role="complementary" aria-label="Contact information">
  <div class="topbar__inner">
    <div class="topbar__left">
      <span class="topbar__item">
        <span class="topbar__dot" aria-hidden="true"></span>
        Stanwell, TW19 · Surrey
      </span>
      <span class="topbar__item topbar__item--hide-sm">Mon-Fri 09:00-18:00 · Sat 09:00-16:00</span>
      <span class="topbar__item topbar__item--hide-sm">
        <span class="topbar__pulse" aria-hidden="true"></span>
        Emergency 24/7
      </span>
    </div>
    <div class="topbar__right">
      <a href="https://www.instagram.com/hardwirecore" class="topbar__social" aria-label="Instagram">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.5" y2="6.5"></line></svg>
        <span>Instagram</span>
      </a>
      <a href="https://www.facebook.com/hardwirecore" class="topbar__social" aria-label="Facebook">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        <span>Facebook</span>
      </a>
      <a href="https://wa.me/447575701219" class="topbar__social" aria-label="WhatsApp">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        <span>WhatsApp</span>
      </a>
    </div>
  </div>
</div>

<header class="header" role="banner" id="header">
  <a href="/" class="logo" aria-label="Hardwire Core - Homepage">
    <div class="logo__hex" aria-hidden="true">
      <div class="logo__hex-outer"></div>
      <div class="logo__hex-inner"></div>
    </div>
    <div class="logo__text">
      <span class="logo__name">Hardwire <em>Core</em></span>
      <span class="logo__sub">// Computer Service · TW19</span>
    </div>
  </a>

  <nav class="navbar" role="navigation" aria-label="Main navigation">
    <ul class="navbar__menu" role="menubar" id="navbarMenu">
      <div class="mobile-header">
        <div class="mobile-header__logo">
          <div class="logo__hex logo__hex--sm">
            <div class="logo__hex-outer"></div>
            <div class="logo__hex-inner"></div>
          </div>
          <div class="logo__text">
            <span class="logo__name">Hardwire <em>Core</em></span>
            <span class="logo__sub">// Computer Service · TW19</span>
          </div>
        </div>
        <a href="tel:+447575701219" class="mobile-header__phone">
          <span class="topbar__pulse"></span>
          +44 7575 701 219
        </a>
      </div>

      <li class="navbar__item" role="none">
        <a href="/" class="navbar__link" role="menuitem" aria-label="Home">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          <span>Home</span>
        </a>
      </li>

      <li class="navbar__item" role="none">
        <a href="/services/" class="navbar__link" role="menuitem" aria-label="Services">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          <span>Services</span>
        </a>
      </li>

      <li class="navbar__item" role="none">
        <a href="/#mfest" class="navbar__link" role="menuitem" aria-label="About">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
          <span>About</span>
        </a>
      </li>

      <li class="navbar__item" role="none">
        <a href="#" class="navbar__link" role="menuitem" aria-label="Contact" onclick="event.preventDefault(); openContactModal();">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          <span>Contact</span>
        </a>
      </li>

      <li class="navbar__item navbar__item--cta" role="none">
        <a href="#" class="navbar__link navbar__link--book" role="menuitem" aria-label="Book Repair Now" onclick="event.preventDefault(); openContactModal();">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
          <span>Book Now</span>
        </a>
      </li>

      <div class="mobile-socials" aria-label="Social media links">
        <a href="https://www.instagram.com/hardwirecore" class="mobile-socials__icon" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.5" y2="6.5"></line></svg>
        </a>
        <a href="https://www.facebook.com/hardwirecore" class="mobile-socials__icon" aria-label="Facebook">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="https://wa.me/447575701219" class="mobile-socials__icon" aria-label="WhatsApp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        </a>
      </div>
    </ul>
  </nav>

  <div class="header__actions">
    <div class="header__phone-block">
      <span class="header__phone-tag">// Quick contact</span>
      <a href="tel:+447575701219" class="header__phone">
        <span class="topbar__pulse" aria-hidden="true"></span>
        +44 7575 701 219
      </a>
    </div>
    <a href="#" class="header__cta" aria-label="Book a repair" onclick="event.preventDefault(); openContactModal();">
      Book Repair
      <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M1 11L11 1M11 1H3M11 1V9" stroke="white" stroke-width="1.5"></path></svg>
    </a>
  </div>

  <div class="menu-toggle-container">
    <div class="menu-toggle" id="menuToggle" role="button" aria-label="Toggle navigation" aria-expanded="false" tabindex="0">
      <input type="checkbox" id="menuCheckbox" aria-label="Toggle Main Menu">
      <svg aria-hidden="true">
        <use xlink:href="#hw-menu"></use>
        <use xlink:href="#hw-menu"></use>
      </svg>
    </div>
  </div>

  <ContactModal />
</header>

<svg xmlns="http://www.w3.org/2000/svg" style="display:none;">
  <symbol viewBox="0 0 100 56" id="hw-menu">
    <path d="M48.33,45.6H18a14.17,14.17,0,0,1,0-28.34H78.86a17.37,17.37,0,0,1,0,34.74H42.33l-21-21.26L47.75,4"></path>
  </symbol>
</svg>
