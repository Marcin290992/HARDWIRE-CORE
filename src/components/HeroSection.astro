---
import heroVideo from '../assets/video/hardwire core hero.webm';
---

<section class="hw-hero" aria-label="Hero section">
  <div class="hw-hero__video-wrap">
    <video class="hw-hero__video" autoplay muted loop playsinline preload="none" aria-hidden="true">
      <source src={heroVideo} type="video/webm">
    </video>
  </div>

  <div class="hw-hero__grid" aria-hidden="true"></div>

  <div class="hw-hero__inner !px-4 sm:!px-6 md:!px-8 lg:!px-10 xl:!px-12">
    <div class="hw-hero__content">
      <span class="hw-hero__tag">Professional Computer Service</span>

      <h1 class="hw-hero__title">
        Computer problems<br>
        <em>fixed</em> like magic
      </h1>

      <div class="hw-hero__badge" aria-label="AI Diagnostics Technology">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"></path>
        </svg>
        AI-Powered Diagnostics
      </div>

      <p class="hw-hero__desc">
        At Hardwire Core, I combine years of hands-on expertise with cutting-edge AI diagnostic tools to solve your computer problems faster than ever. No fix, no fee. Guaranteed.
      </p>

      <div class="hw-hero__features">
        <div class="hw-hero__card hw-hero__card--ai">
          <div class="hw-hero__card-icon">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
          </div>
          <div class="hw-hero__card-title">AI-Powered Speed</div>
          <div class="hw-hero__card-text">Advanced algorithms cut diagnosis time by up to 60%.</div>
        </div>

        <div class="hw-hero__card">
          <div class="hw-hero__card-icon">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <div class="hw-hero__card-title">Data Security</div>
          <div class="hw-hero__card-text">Your files stay private - military-grade protocols.</div>
        </div>

        <div class="hw-hero__card">
          <div class="hw-hero__card-icon">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <div class="hw-hero__card-title">Guaranteed Results</div>
          <div class="hw-hero__card-text">No fix, no fee - backed by full warranty.</div>
        </div>
      </div>

      <div class="hw-hero__cta">
        <a href="/booking/" class="hw-hero__btn-primary" aria-label="Book a repair">
          <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 11 12 14 22 4"></polyline>
            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
          </svg>
          Book Now
        </a>
        <a href="/about/" class="hw-hero__btn-secondary" aria-label="About Hardwire Core">
          <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
          About Me
        </a>
      </div>
    </div>

    <div class="hw-hero__visual" aria-hidden="true">
      <div class="hw-hero__img-wrap">
        <span class="hw-hero__bracket hw-hero__bracket--tl"></span>
        <span class="hw-hero__bracket hw-hero__bracket--tr"></span>
        <span class="hw-hero__bracket hw-hero__bracket--bl"></span>
        <span class="hw-hero__bracket hw-hero__bracket--br"></span>

        <img
          src="https://pchoudini.com/wp-content/uploads/2025/05/HZN_EXP_C_BRB_GAME_C_01.webp"
          alt="Professional laptop repair by Hardwire Core"
          class="hw-hero__img"
          loading="eager"
          decoding="async"
        >

        <div class="hw-hero__status">
          <span class="hw-hero__status-dot"></span>
          System diagnostic online
        </div>
      </div>
    </div>
  </div>
</section>
