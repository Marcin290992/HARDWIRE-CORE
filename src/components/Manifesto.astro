<section class="manifesto" aria-label="About Hardwire Core">
  <div class="manifesto__topline" aria-hidden="true"></div>

  <div class="manifesto__inner !px-4 sm:!px-6 md:!px-8 lg:!px-10 xl:!px-12">
    <div class="manifesto__left">
      <span class="manifesto__eyebrow">// Who I am</span>

      <h2 class="manifesto__heading">
        Not a shop.<br>
        Not a call centre.<br>
        <em>Just me.</em>
      </h2>

      <ul class="manifesto__codex" role="list">
        <li class="manifesto__line">
          <span class="manifesto__line-num" aria-hidden="true">01</span>
          <span class="manifesto__line-text">I diagnose first. I never guess your money away.</span>
        </li>
        <li class="manifesto__line">
          <span class="manifesto__line-num" aria-hidden="true">02</span>
          <span class="manifesto__line-text">No fix - no fee. That's not marketing. That's a promise.</span>
        </li>
        <li class="manifesto__line">
          <span class="manifesto__line-num" aria-hidden="true">03</span>
          <span class="manifesto__line-text">Your data stays yours. I don't touch what I don't need to.</span>
        </li>
        <li class="manifesto__line">
          <span class="manifesto__line-num" aria-hidden="true">04</span>
          <span class="manifesto__line-text">I tell you what's wrong in plain English. Always.</span>
        </li>
      </ul>

      <a href="/about/" class="manifesto__link" aria-label="More about Hardwire Core">
        Meet the engineer
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M1 11L11 1M11 1H3M11 1V9" stroke="currentColor" stroke-width="1.5"></path>
        </svg>
      </a>
    </div>

    <div class="manifesto__divider" aria-hidden="true"></div>

    <div class="manifesto__right" aria-label="Key facts">
      <div class="manifesto__stat">
        <span class="manifesto__stat-num">500<em>+</em></span>
        <span class="manifesto__stat-label">Repairs completed</span>
      </div>

      <div class="manifesto__sep" aria-hidden="true"></div>

      <div class="manifesto__stat">
        <span class="manifesto__stat-num">5<em>+</em></span>
        <span class="manifesto__stat-label">Years hands-on experience</span>
      </div>

      <div class="manifesto__sep" aria-hidden="true"></div>

      <div class="manifesto__stat">
        <span class="manifesto__stat-num">4.9<em>*</em></span>
        <span class="manifesto__stat-label">Google rating · Stanwell TW19</span>
      </div>

      <div class="manifesto__badge" aria-label="No fix no fee guarantee">
        <span class="manifesto__badge-dot" aria-hidden="true"></span>
        No fix · No fee · Guaranteed
      </div>
    </div>
  </div>

  <div class="manifesto__bottomline" aria-hidden="true"></div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const REVEAL_ID = 'manifesto-reveal';

  const initManifestoAnimation = () => {
    const section = document.querySelector<HTMLElement>('.manifesto');
    if (!section) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.matchMedia('(max-width: 992px)').matches;
    const targets = section.querySelectorAll<HTMLElement>(
      '.manifesto__eyebrow, .manifesto__heading, .manifesto__line, .manifesto__stat, .manifesto__badge, .manifesto__link'
    );

    ScrollTrigger.getById(REVEAL_ID)?.kill();
    gsap.killTweensOf(targets);

    if (reduceMotion || isMobile) {
      gsap.set(targets, { clearProps: 'all', autoAlpha: 1, y: 0 });
      return;
    }

    gsap.set(targets, { autoAlpha: 0, y: 16 });

    const tl = gsap.timeline({ paused: true, defaults: { duration: 0.55, ease: 'power2.out' } });

    tl.to(section.querySelector('.manifesto__eyebrow'), { autoAlpha: 1, y: 0 })
      .to(section.querySelector('.manifesto__heading'), { autoAlpha: 1, y: 0 }, '-=0.35')
      .to(section.querySelectorAll('.manifesto__line'), { autoAlpha: 1, y: 0, stagger: 0.1 }, '-=0.25')
      .to(section.querySelectorAll('.manifesto__stat'), { autoAlpha: 1, y: 0, stagger: 0.1 }, '-=0.12')
      .to([section.querySelector('.manifesto__badge'), section.querySelector('.manifesto__link')], { autoAlpha: 1, y: 0 }, '-=0.25');

    ScrollTrigger.create({
      id: REVEAL_ID,
      trigger: section,
      start: 'top 82%',
      once: true,
      onEnter: () => tl.play(0),
      onEnterBack: () => tl.play(0),
    });

    ScrollTrigger.refresh();
  };

  const runManifestoAnimation = () => {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => initManifestoAnimation());
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', runManifestoAnimation, { once: true });
  } else {
    runManifestoAnimation();
  }

  document.addEventListener('astro:page-load', runManifestoAnimation);
  document.addEventListener('astro:after-swap', runManifestoAnimation);
</script>
