  50% {
    opacity: 0.45;
  }
}
</style>

<script>
(() => {
  const initManifesto = () => {
    const section = document.getElementById('mfest');
    if (!section) return;
    if (section.dataset.mfestInit === '1') return;
    section.dataset.mfestInit = '1';

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealTargets = section.querySelectorAll('.mfest__reveal');

    revealTargets.forEach((el) => {
      const delay = Number(el.getAttribute('data-delay') || '0');
      el.style.setProperty('--mfest-delay', `${delay}ms`);
    });

    if (reduceMotion) {
      revealTargets.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        obs.unobserve(entry.target);
      });
    }, { threshold: 0.22 });

    revealTargets.forEach((el) => observer.observe(el));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initManifesto, { once: true });
  } else {
    initManifesto();
  }

  document.addEventListener('astro:page-load', initManifesto);
})();
</script>
