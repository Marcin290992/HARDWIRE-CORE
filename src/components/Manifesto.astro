<style>
.mfest {
  position: relative;
  background: var(--bg);
  overflow: hidden;
}

.mfest::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.12) 2px, rgba(0, 0, 0, 0.12) 4px);
  pointer-events: none;
  z-index: 0;
}

.mfest > * {
  position: relative;
  z-index: 1;
}

.mfest__line {
  height: 1px;
}

.mfest__line--top {
  background: linear-gradient(to right, transparent, rgba(220, 38, 38, 0.55), transparent);
}

.mfest__line--bottom {
  background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.08), transparent);
}

.mfest__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 4.5rem 1.5rem 5rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.6rem;
}

@media (min-width: 768px) {
  .mfest__inner {
    padding: 5.5rem 2.5rem 6rem;
  }
}

@media (min-width: 1024px) {
  .mfest__inner {
    grid-template-columns: minmax(0, 1fr) 1px 360px;
