---
---

<div id="contactModal" class="contact-modal">
  <div class="contact-modal__box">
    <div class="contact-modal__redline"></div>
    <button
      class="contact-modal__close"
      onclick="document.getElementById('contactModal').classList.remove('is-open')"
      aria-label="Close modal"
    >×</button>

    <div class="contact-modal__inner">
      <p class="contact-modal__eyebrow">// Get in touch</p>
      <h2 class="contact-modal__heading">Contact</h2>

      <div class="contact-modal__cards">
        <a href="https://wa.me/447575701219" class="contact-card contact-card--wa" target="_blank" rel="noopener noreferrer">
          <svg class="contact-card__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
          <span class="contact-card__label">WhatsApp</span>
          <span class="contact-card__value">+44 7575 701 219</span>
        </a>
        <a href="mailto:contact@hardwirecore.co.uk" class="contact-card contact-card--email">
          <svg class="contact-card__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <polyline points="22,4 12,13 2,4"></polyline>
          </svg>
          <span class="contact-card__label">Email</span>
          <span class="contact-card__value">contact@hardwirecore.co.uk</span>
        </a>
      </div>

      <hr class="contact-modal__divider" />

      <p class="contact-modal__eyebrow contact-modal__eyebrow--sm">// Send a message</p>
      <textarea
        id="contactMsg"
        class="contact-modal__textarea"
        placeholder="Describe your issue briefly..."
      ></textarea>

      <div class="contact-modal__actions">
        <button class="contact-btn contact-btn--primary contact-btn--full" onclick="sendContactWhatsapp()">
          Send
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .contact-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.75);
    padding: 1rem;
  }
  .contact-modal.is-open {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact-modal__box {
    background: var(--bg);
    border: 1px solid var(--red-border);
    max-width: 480px;
    width: 100%;
    clip-path: var(--clip-cut);
    position: relative;
  }
  .contact-modal__redline {
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--red), transparent);
  }
  .contact-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
    z-index: 1;
    transition: color 0.2s;
  }
  .contact-modal__close:hover {
    color: var(--red);
  }
  .contact-modal__inner {
    padding: 1.75rem 1.75rem 1.5rem;
  }
  .contact-modal__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 0.5rem;
  }
  .contact-modal__eyebrow--sm {
    margin-top: 0;
  }
  .contact-modal__heading {
    font-family: var(--font-head);
    font-size: 1.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 1.25rem;
    line-height: 1;
  }
  .contact-modal__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    padding: 0.85rem 1rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid;
    transition: opacity 0.2s;
  }
  .contact-card:hover {
    opacity: 0.8;
  }
  .contact-card--wa,
  .contact-card--email {
    border-color: var(--border);
    background: rgba(255, 255, 255, 0.02);
  }
  .contact-card__icon {
    color: var(--red);
  }
  .contact-card__label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(220, 38, 38, 0.6);
    margin-top: 0.15rem;
  }
  .contact-card__value {
    font-size: 0.8rem;
    font-weight: 500;
  }
  .contact-modal__divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 1.25rem 0;
  }
  .contact-modal__textarea {
    display: block;
    width: 100%;
    height: 90px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    color: inherit;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.75rem;
    resize: vertical;
    outline: none;
    box-sizing: border-box;
    margin-top: 0.5rem;
    transition: border-color 0.2s;
  }
  .contact-modal__textarea:focus {
    border-color: var(--red-border);
  }
  .contact-modal__actions {
    margin-top: 0.75rem;
  }
  .contact-btn--full {
    width: 100%;
  }
  .contact-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    clip-path: var(--clip-cut);
    transition: opacity 0.2s;
  }
  .contact-btn:hover {
    opacity: 0.85;
  }
  .contact-btn--primary {
    background: var(--red);
    color: #fff;
    border: none;
  }
  .contact-btn--secondary {
    background: transparent;
    color: inherit;
    border: 1px solid var(--border);
  }
</style>

<script is:inline>
  document.addEventListener('click', function(e) {
    var modal = document.getElementById('contactModal');
    if (modal && e.target === modal) modal.classList.remove('is-open');
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') document.getElementById('contactModal')?.classList.remove('is-open');
  });
  function openContactModal() {
    document.getElementById('contactModal').classList.add('is-open');
  }
  function sendContactWhatsapp() {
    var msg = document.getElementById('contactMsg').value;
    window.open('https://wa.me/447575701219?text=' + encodeURIComponent(msg), '_blank');
  }
  function sendContactEmail() {
    var msg = document.getElementById('contactMsg').value;
    window.location.href = 'mailto:contact@hardwirecore.co.uk?body=' + encodeURIComponent(msg);
  }
</script>
