  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.4; }
}
</style>

<script>
(function () {
  const root = document.getElementById('services-cockpit');
  if (!root) return;

  const navItems = root.querySelectorAll<HTMLButtonElement>('.services__nav-item');
  const panels = root.querySelectorAll<HTMLElement>('.services__panel');
  const meter = document.getElementById('services-meter-fill');
  const stage = document.getElementById('svc-stage');
  const activeTitle = document.getElementById('services-active-title');
  const serviceSection = document.getElementById('services');
  let pulseTimer: ReturnType<typeof window.setTimeout> | undefined;

  const serviceIds = new Set(
    Array.from(navItems)
      .map((item) => item.dataset.serviceId)
      .filter((value): value is string => Boolean(value))
  );

  const activate = (serviceId: string, updateHash = false) => {
    const total = navItems.length;
    navItems.forEach((item, idx) => {
      const active = item.dataset.serviceId === serviceId;
      item.classList.toggle('is-active', active);
      item.setAttribute('aria-selected', active ? 'true' : 'false');
      if (active && meter) {
        const width = total > 0 ? ((idx + 1) / total) * 100 : 0;
        meter.style.width = `${width}%`;
      }
      if (active && activeTitle) {
        const title = item.querySelector('.services__nav-title')?.textContent?.trim();
        if (title) activeTitle.textContent = title;
      }
    });

    panels.forEach((panel) => {
      panel.classList.toggle('is-active', panel.dataset.panel === serviceId);
    });

    if (stage) {
      stage.classList.remove('is-pulsing');
      window.clearTimeout(pulseTimer);
      void stage.offsetWidth;
      stage.classList.add('is-pulsing');
      pulseTimer = window.setTimeout(() => stage.classList.remove('is-pulsing'), 450);
    }

    if (updateHash) {
      const url = new URL(window.location.href);
      url.hash = serviceId;
      window.history.replaceState({}, '', url);
    }
  };

  const syncFromHash = () => {
    const hash = window.location.hash.replace(/^#/, '');
    if (!hash) return;

    if (serviceIds.has(hash)) {
      activate(hash);
      if (serviceSection) {
        window.requestAnimationFrame(() => {
          serviceSection.scrollIntoView({ behavior: 'auto', block: 'start' });
        });
      }
    }
  };

  navItems.forEach((item) => {
    item.addEventListener('click', () => {
      const id = item.dataset.serviceId;
      if (!id) return;

      activate(id, true);

      if (window.matchMedia('(max-width: 1023px)').matches && stage) {
        window.requestAnimationFrame(() => {
          stage.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
    });
  });

  const first = navItems[0]?.dataset.serviceId;
  if (first) activate(first);
  syncFromHash();
  window.addEventListener('hashchange', syncFromHash);

  const revealItems = document.querySelectorAll<HTMLElement>('.services__nav, .services__stage, .services__meter, .services__bottom');
  if (!revealItems.length) return;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      entry.target.classList.add('in-view');
      observer.unobserve(entry.target);
    });
  }, { threshold: 0.08 });

  revealItems.forEach((el) => observer.observe(el));
})();
</script>
