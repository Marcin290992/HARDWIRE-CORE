---
const bookingBase = 'https://wa.me/447575701219?text=';

const services = [
  {
    id: "laptop-repairs",
    hero: true,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 7h.01M7 11h.01M11 7h6M11 11h6"/></svg>`,
    title: "Laptop Repairs",
    desc: "Screen replacements, keyboard fixes, charging ports, motherboard diagnosis — handled same day whenever possible.",
    time: "Same day",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Laptop Repairs.")}`,
    tag: "Most popular",
  },
  {
    id: "desktop-repairs",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: "Desktop PC Repairs",
    desc: "Power supply failures, GPU issues, no POST diagnostics. I fix what others give up on.",
    time: "1–2 days",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Desktop PC Repairs.")}`,
  },
  {
    id: "virus-removal",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
    title: "Virus & Malware Removal",
    desc: "Deep scan, full clean, browser reset. Your machine back to safe and fast.",
    time: "Same day",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Virus & Malware Removal.")}`,
  },
  {
    id: "data-recovery",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>`,
    title: "Data Recovery",
    desc: "Failed drives, accidental deletes, corrupted partitions. Photos, documents — recovered.",
    time: "2–3 days",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Data Recovery.")}`,
  },
  {
    id: "screen-replacement",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    title: "Screen Replacement",
    desc: "Cracked or dead display? Genuine quality panels fitted fast, laptop or desktop.",
    time: "Same day",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Screen Replacement.")}`,
  },
  {
    id: "os-installation",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: "OS Installation",
    desc: "Fresh Windows or Linux install, drivers, updates. Clean slate, nothing missing.",
    time: "Same day",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book OS Installation.")}`,
  },
  {
    id: "speed-boost",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    title: "Speed Enhancement",
    desc: "Startup optimisation, bloatware removal, thermal repaste. Feels like new hardware.",
    time: "Same day",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Speed Enhancement.")}`,
  },
  {
    id: "hardware-upgrades",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    title: "Hardware Upgrades",
    desc: "RAM, SSD, GPU. I spec the right parts and fit them correctly — no guesswork.",
    time: "Same day",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Hardware Upgrades.")}`,
  },
  {
    id: "deep-cleaning",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: "Deep Cleaning",
    desc: "Dust removal, fan clean, thermal compound replacement. Stops overheating for good.",
    time: "Same day",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Deep Cleaning.")}`,
  },
  {
    id: "network-setup",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="16" y="16" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><path d="M5 16v-4h14v4M12 12V8"/></svg>`,
    title: "Network Setup",
    desc: "Router config, Wi-Fi extenders, wired runs. Strong signal everywhere in your home.",
    time: "Same day",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Network Setup.")}`,
  },
  {
    id: "software-troubleshooting",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>`,
    title: "Software Troubleshooting",
    desc: "Crashes, freezes, error loops. I diagnose and fix what's broken — or explain why.",
    time: "Same day",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book Software Troubleshooting.")}`,
  },
  {
    id: "health-check",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    title: "PC Health Check",
    desc: "Full diagnostic of hardware and software. Know exactly what's wrong — and what isn't.",
    time: "1–2 hrs",
    href: `${bookingBase}${encodeURIComponent("Hi, I'd like to book a PC Health Check.")}`,
    tag: "Free assessment",
  },
];

const orderedServices = services;
---

<section class="services" aria-label="Services" id="services">

  <div class="services__top-line"></div>

  <div class="services__inner">

    <div class="services__header">
      <div>
        <span class="services__eyebrow">// What I fix</span>
        <span class="services__title-line" aria-hidden="true"></span>
        <h2 class="services__title">
          Choose one service.<br>
          <em>Focus on what matters.</em>
        </h2>
      </div>
      <p class="services__sub">
        Instead of dumping everything at once, pick a single service from the list and view full details on the live stage.
      </p>
    </div>

    <div class="services__cockpit" id="services-cockpit">
      <aside class="services__nav" role="tablist" aria-label="Services list">
        <div class="services__nav-intro">
          <span class="services__nav-intro-label">Pick a service</span>
          <p class="services__nav-intro-text">Tap any item to update the service preview below.</p>
        </div>

        {orderedServices.map((s, i) => (
          <button
            type="button"
            class={`services__nav-item ${i === 0 ? 'is-active' : ''}`}
            data-service-id={s.id}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`service-panel-${s.id}`}
          >
            <span class="services__nav-index">{String(i + 1).padStart(2, '0')}</span>
            <span class="services__nav-title">{s.title}</span>
            <span class="services__nav-time">{s.time}</span>
          </button>
        ))}
      </aside>

      <div class="services__stage-wrap">
        <div class="services__stage" id="svc-stage">
          <div class="services__stage-top"></div>
          <div class="services__stage-status" aria-live="polite">
            <span class="services__stage-status-label">Live Preview</span>
            <p class="services__stage-status-text">
              Now viewing: <span id="services-active-title">{orderedServices[0].title}</span>
            </p>
          </div>
          <span class="bracket bracket--tl"></span>
          <span class="bracket bracket--br"></span>
          <div class="services__stage-grid" aria-hidden="true"></div>
          <div class="services__scanner" aria-hidden="true"></div>

          {orderedServices.map((s, i) => (
            <article
              class={`services__panel ${i === 0 ? 'is-active' : ''}`}
              data-panel={s.id}
              data-idx={String(i)}
              id={`service-panel-${s.id}`}
              role="tabpanel"
            >
              <header class="services__panel-head">
                <div class="services__panel-icon" set:html={s.icon}></div>
                <div>
                  <span class="services__panel-kicker">Service {String(i + 1).padStart(2, '0')}</span>
                  <h3 class="services__panel-title">{s.title}</h3>
                </div>
              </header>

              <p class="services__panel-desc">{s.desc}</p>

              <div class="services__terminal" aria-label="Service terminal preview">
                <div class="services__terminal-head">
                  <span class="services__terminal-dot"></span>
                  <span class="services__terminal-dot"></span>
                  <span class="services__terminal-dot"></span>
                  <span class="services__terminal-title">hardwire://service-node</span>
                </div>
                <div class="services__terminal-body">
                  <p><span>$ service</span> {s.id}</p>
                  <p><span>$ turnaround</span> {s.time}</p>
                  <p><span>$ status</span> ready_for_booking</p>
                </div>
              </div>

              <div class="services__panel-meta">
                <span class="services__time">
                  <svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {s.time}
                </span>
                {s.tag && <span class="services__panel-tag">{s.tag}</span>}
              </div>

              <a href={s.href} class="services__cta" target="_blank" rel="noreferrer">
                <span>Book service</span>
                <svg viewBox="0 0 12 12" fill="none"><path d="M1 11L11 1M11 1H3M11 1V9" stroke="white" stroke-width="1.5"/></svg>
                <span class="services__cta-shine" aria-hidden="true"></span>
              </a>
            </article>
          ))}
        </div>

        <div class="services__meter" aria-live="polite">
          <span class="services__meter-label">Selection Focus</span>
          <div class="services__meter-track"><span class="services__meter-fill" id="services-meter-fill"></span></div>
        </div>
      </div>
    </div>

    <div class="services__bottom">
      <div class="services__bottom-left">
        <span class="services__bottom-dot"></span>
        <p class="services__bottom-text">Not sure what you need? <span class="services__bottom-em">Start with a free diagnostic.</span></p>
      </div>
      <a href="/contact/" class="services__bottom-cta">
        Get in touch
        <svg viewBox="0 0 12 12" fill="none"><path d="M1 11L11 1M11 1H3M11 1V9" stroke="currentColor" stroke-width="1.5"/></svg>
      </a>
    </div>

  </div>

  <div class="services__bottom-line"></div>

</section>

<style>
.services {
  position: relative;
  background: var(--bg);
  overflow: hidden;
}

/* scan-line texture */
.services::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(
    0deg, transparent, transparent 2px,
    rgba(0,0,0,0.12) 2px, rgba(0,0,0,0.12) 4px
  );
  pointer-events: none;
  z-index: 0;
}

.services > * { position: relative; z-index: 1; }

.services__top-line {
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(220,38,38,0.5), transparent);
}

.services__bottom-line {
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(255,255,255,0.08), transparent);
}

/* ── Inner ── */
.services__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 4.5rem 1.5rem 5rem;
}

@media (min-width: 768px)  { .services__inner { padding: 5.5rem 2.5rem 6rem; } }
@media (min-width: 1280px) { .services__inner { padding: 6rem 3rem 6.5rem; } }

.services__header {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  margin-bottom: 2rem;
}

@media (min-width: 768px) {
  .services__header {
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
  }
}

.services__eyebrow {
  display: block;
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 0.75rem;
}

.services__title-line {
  display: block;
  width: 32px;
  height: 2px;
  background: var(--red);
  margin-bottom: 0.75rem;
}

.services__title {
  font-family: var(--font-head);
  font-size: clamp(1.7rem, 3.6vw, 2.8rem);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--text);
  line-height: 1.1;
}

.services__title em {
  font-style: normal;
  color: var(--red);
}

.services__sub {
  font-family: var(--font-body);
  font-size: 0.82rem;
  color: var(--text-mid);
  max-width: 24rem;
  line-height: 1.625;
}

@media (min-width: 768px) { .services__sub { text-align: right; } }

.services__cockpit {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}

@media (min-width: 1024px) {
  .services__cockpit {
    grid-template-columns: 340px 1fr;
    align-items: stretch;
    gap: 1rem;
  }
}

.services__nav {
  background: rgba(255,255,255,0.02);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  border: 1px solid var(--border);
  clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));
  padding: 0.65rem;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.services__nav-intro {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding: 0.55rem 0.6rem 0.75rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 0.15rem;
}

.services__nav-intro-label {
  font-family: var(--font-mono);
  font-size: 8px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--red);
}

.services__nav-intro-text {
  font-family: var(--font-body);
  font-size: 0.82rem;
  line-height: 1.55;
  color: var(--text-muted);
}

.services__nav-item {
  width: 100%;
  border: 1px solid transparent;
  color: var(--text-mid);
  display: grid;
  grid-template-columns: 34px 1fr auto;
  align-items: center;
  gap: 0.7rem;
  padding: 0.75rem 0.65rem;
  clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
  transition: border-color 0.25s var(--ease), color 0.25s var(--ease), background 0.25s var(--ease);
}

.services__nav-item:hover {
  border-color: rgba(220,38,38,0.32);
  color: var(--text);
  background: rgba(220,38,38,0.05);
}

.services__nav-item.is-active {
  border-color: rgba(220,38,38,0.45);
  color: var(--text);
  background: linear-gradient(to right, rgba(220,38,38,0.1), transparent);
}

.services__nav-item.is-active .services__nav-index {
  opacity: 1;
  text-shadow: 0 0 6px rgba(220,38,38,0.6);
}

.services__nav-item.is-active .services__nav-time {
  color: var(--red);
}

.services__nav-index {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.24em;
  color: rgba(220,38,38,0.7);
}

.services__nav-title {
  font-family: var(--font-head);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-align: left;
}

.services__nav-time {
  font-family: var(--font-mono);
  font-size: 8px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.services__stage-wrap {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}

.services__stage {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(220,38,38,0.32);
  background: linear-gradient(to bottom, rgba(10,10,12,1), rgba(18,18,22,1));
  clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  min-height: 410px;
}

.services__stage.is-pulsing {
  border-color: rgba(220,38,38,0.7);
}

.services__stage-top {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--red);
}

.services__stage-status {
  position: relative;
  z-index: 11;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.9rem;
  padding: 1rem 1.15rem 0;
}

.services__stage-status-label {
  flex-shrink: 0;
  font-family: var(--font-mono);
  font-size: 8px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--red);
}

.services__stage-status-text {
  font-family: var(--font-body);
  font-size: 0.88rem;
  line-height: 1.5;
  color: var(--text-mid);
  text-align: right;
}

.services__stage-status-text span {
  color: var(--text);
}

.bracket {
  position: absolute;
  width: 18px;
  height: 18px;
  border-color: rgba(220,38,38,0.45);
  border-style: solid;
  transition: border-color 0.3s ease;
  z-index: 10;
}
.bracket--tl { top: 10px; left: 10px; border-width: 2px 0 0 2px; }
.bracket--br { bottom: 10px; right: 10px; border-width: 0 2px 2px 0; }

.services__stage-grid {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.26;
  background-image:
    linear-gradient(rgba(220,38,38,0.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(220,38,38,0.045) 1px, transparent 1px);
  background-size: 40px 40px;
}

.services__scanner {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(180deg, transparent 0%, rgba(220,38,38,0.1) 49%, transparent 51%, transparent 100%);
  transform: translateY(-110%);
  animation: scanner-pass 4s linear infinite;
  opacity: 0.6;
}

.services__panel {
  position: relative;
  z-index: 10;
  padding: 1.4rem 2rem 1.8rem;
  display: none;
}

.services__panel.is-active {
  display: block;
  animation: panel-in 300ms var(--ease);
}

.services__panel-head {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
}

.services__panel-icon {
  width: 68px;
  height: 68px;
  background-color: rgba(220,38,38,0.08);
  border: 1px solid rgba(220,38,38,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  box-shadow: 0 0 0 1px rgba(220,38,38,0.3), 0 0 24px rgba(220,38,38,0.12);
}

.services__panel-icon :global(svg) {
  width: 32px;
  height: 32px;
  stroke: var(--red);
}

.services__panel-kicker {
  display: block;
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(220,38,38,0.75);
  margin-bottom: 0.35rem;
}

.services__panel-title {
  font-family: var(--font-head);
  font-size: clamp(1.45rem, 2.9vw, 2.45rem);
  text-transform: uppercase;
  letter-spacing: 0.035em;
  color: var(--text);
  line-height: 1.2;
  background: linear-gradient(135deg, #ffffff 40%, rgba(220,38,38,0.85) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.services__panel-desc {
  font-family: var(--font-body);
  font-size: 1.03rem;
  color: var(--text-muted);
  line-height: 1.75;
  max-width: 58ch;
  margin-bottom: 1.2rem;
}

.services__terminal {
  border: 1px solid var(--border);
  background: var(--bg3);
  margin-bottom: 1rem;
  clip-path: polygon(0 0, calc(100% - 9px) 0, 100% 9px, 100% 100%, 9px 100%, 0 calc(100% - 9px));
}

.services__terminal-head {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  border-bottom: 1px solid var(--border);
  padding: 0.55rem 0.72rem;
}

.services__terminal-dot {
  width: 7px;
  height: 7px;
  background: rgba(220,38,38,0.75);
}

.services__terminal-title {
  margin-left: 0.35rem;
  font-family: var(--font-mono);
  font-size: 8.5px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.services__terminal-body {
  padding: 0.72rem;
}

.services__terminal-body p {
  font-family: var(--font-mono);
  font-size: 10px;
  line-height: 1.55;
  letter-spacing: 0.08em;
  color: var(--text-mid);
  text-transform: lowercase;
}

.services__terminal-body p + p {
  margin-top: 0.35rem;
}

.services__terminal-body span {
  color: var(--red);
  text-shadow: 0 0 8px rgba(220,38,38,0.5);
}

.services__terminal-body p:last-child::after {
  content: '\25CB';
  display: inline-block;
  margin-left: 0.5em;
  color: var(--red);
  animation: blink-cursor 1s step-end infinite;
}

@keyframes blink-cursor {
