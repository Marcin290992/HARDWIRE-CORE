---
import Layout from '../layouts/Layout.astro';
import SiteMenu from '../components/SiteMenu.astro';
import Footer  from '../components/Footer.astro';
---

<Layout
  title="About – Hardwire Core"
  description="Meet the engineer behind Hardwire Core. One-man repair studio in Stanwell TW19 — honest diagnostics, no-fix-no-fee, 500+ repairs and counting."
>
  <SiteMenu />

  <main class="about-stack">

    <!-- ═══ PANEL 1 — HERO ═══ -->
    <section class="about-panel about-panel--hero">
      <div class="about-panel__inner">
        <span class="about-eyebrow">// About</span>
        <h1 class="about-hero__heading">
          One engineer.<br />
          One workbench.<br />
          <em>Zero bullshit.</em>
        </h1>
        <p class="about-hero__sub">
          Hardwire Core is not a chain, not a call centre, not a faceless ticket system.<br />
          It's me — diagnosing, repairing and returning your machine the same day whenever I can.
        </p>
        <div class="about-hero__scroll-hint" aria-hidden="true">
          <svg width="20" height="32" viewBox="0 0 20 32" fill="none"><rect x="1" y="1" width="18" height="30" rx="9" stroke="currentColor" stroke-width="1.4"/><circle cx="10" cy="10" r="2" fill="currentColor" class="about-dot"/></svg>
        </div>
      </div>
    </section>

    <!-- ═══ PANEL 2 — MY RULES ═══ -->
    <section class="about-panel about-panel--rules">
      <div class="about-panel__inner">
        <span class="about-eyebrow">// My rules</span>
        <h2 class="about-section__heading">The Hardwire Codex</h2>
        <ul class="about-codex" role="list">
          <li>
            <span class="about-codex__num">01</span>
            <div>
              <strong>Diagnose first.</strong>
              <p>I never guess your money away. Every repair starts with a proper diagnosis — no shortcuts, no assumptions.</p>
            </div>
          </li>
          <li>
            <span class="about-codex__num">02</span>
            <div>
              <strong>No fix — no fee.</strong>
              <p>That's not marketing. That's a promise. If I can't fix it, you don't pay a penny.</p>
            </div>
          </li>
          <li>
            <span class="about-codex__num">03</span>
            <div>
              <strong>Your data stays yours.</strong>
              <p>I don't snoop, I don't copy, I don't touch what I don't need to. Full stop.</p>
            </div>
          </li>
          <li>
            <span class="about-codex__num">04</span>
            <div>
              <strong>Plain English. Always.</strong>
              <p>No jargon walls. I tell you what's wrong, what it costs, and how long it takes — clearly.</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <!-- ═══ PANEL 3 — HOW I WORK ═══ -->
    <section class="about-panel about-panel--process">
      <div class="about-panel__inner">
        <span class="about-eyebrow">// How I work</span>
        <h2 class="about-section__heading">From message to fixed</h2>
        <div class="about-steps">
          <div class="about-step">
            <span class="about-step__icon">01</span>
            <h3>You reach out</h3>
            <p>WhatsApp, call or the form on this site. Tell me what's going on — I'll reply fast.</p>
          </div>
          <div class="about-step">
            <span class="about-step__icon">02</span>
            <h3>Free diagnosis</h3>
            <p>I take a proper look, find the root cause, and quote you a fair price before anything else.</p>
          </div>
          <div class="about-step">
            <span class="about-step__icon">03</span>
            <h3>The repair</h3>
            <p>Hands-on work at my bench. Most jobs done same day. I keep you updated throughout.</p>
          </div>
          <div class="about-step">
            <span class="about-step__icon">04</span>
            <h3>Collect &amp; go</h3>
            <p>Pick up your machine, fully tested. You only pay if it's fixed — guaranteed.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PANEL 4 — STATS ═══ -->
    <section class="about-panel about-panel--stats">
      <div class="about-panel__inner">
        <span class="about-eyebrow">// Track record</span>
        <h2 class="about-section__heading">Numbers don't lie</h2>
        <div class="about-stats">
          <div class="about-stat">
            <span class="about-stat__num">500<em>+</em></span>
            <span class="about-stat__label">Repairs completed</span>
          </div>
          <div class="about-stat">
            <span class="about-stat__num">5<em>+</em></span>
            <span class="about-stat__label">Years hands-on experience</span>
          </div>
          <div class="about-stat">
            <span class="about-stat__num">4.9<em>★</em></span>
            <span class="about-stat__label">Google rating · Stanwell TW19</span>
          </div>
          <div class="about-stat">
            <span class="about-stat__num">0<em>£</em></span>
            <span class="about-stat__label">If I can't fix it</span>
          </div>
        </div>
        <div class="about-badge">
          <span class="about-badge__dot" aria-hidden="true"></span>
          No fix · No fee · Guaranteed
        </div>
      </div>
    </section>

    <!-- ═══ PANEL 5 — CTA (last, not pinned) ═══ -->
    <section class="about-panel about-panel--cta">
      <div class="about-panel__inner">
        <h2 class="about-cta__heading">Ready to get it fixed?</h2>
        <p class="about-cta__sub">Drop me a message — I usually reply within the hour.</p>
        <div class="about-cta__buttons">
          <a href="https://wa.me/447404440404" target="_blank" rel="noopener" class="about-btn about-btn--wa">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.317 0-4.46-.768-6.183-2.064l-.432-.336-3.2 1.072 1.072-3.2-.336-.432A9.953 9.953 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
            WhatsApp
          </a>
          <a href="/#contact" class="about-btn about-btn--outline">Book a repair</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<!-- ═══════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════ -->
<style is:inline>

/* --- layout --- */
.about-stack {
  position: relative;
}

.about-panel {
  width: 100%;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  background: var(--bg);
  overflow: hidden;
  border-radius: 12px;
  will-change: transform, opacity;
}
.about-panel:last-child {
  border-radius: 0;
}

.about-panel__inner {
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  padding: 80px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

/* --- eyebrow --- */
.about-eyebrow {
  font-family: 'Michroma', monospace;
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 28px;
}

/* ═══ PANEL 1 — HERO ═══ */
.about-panel--hero {
  background:
    radial-gradient(ellipse 80% 60% at 50% 40%, rgba(220,38,38,0.06) 0%, transparent 70%),
    var(--bg);
}

.about-hero__heading {
  font-family: 'Michroma', monospace;
  font-size: clamp(2rem, 5vw, 3.6rem);
  line-height: 1.2;
  color: var(--text);
  margin: 0 0 24px;
  font-weight: 400;
}
.about-hero__heading em {
  color: var(--red);
  font-style: normal;
}

.about-hero__sub {
  font-size: clamp(0.95rem, 1.6vw, 1.15rem);
  line-height: 1.7;
  color: var(--text-muted);
  max-width: 600px;
  margin: 0;
}

.about-hero__scroll-hint {
  margin-top: 48px;
  color: rgba(255,255,255,0.2);
}
.about-dot {
  animation: about-bounce 2s ease-in-out infinite;
}
@keyframes about-bounce {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(10px); opacity: 0.3; }
}

/* ═══ PANEL 2 — RULES ═══ */
.about-panel--rules {
  background:
    linear-gradient(180deg, var(--bg2) 0%, var(--bg) 100%);
}

.about-section__heading {
  font-family: 'Michroma', monospace;
  font-size: clamp(1.4rem, 3.2vw, 2.2rem);
  color: var(--text);
  margin: 0 0 40px;
  font-weight: 400;
}

.about-codex {
  list-style: none;
  padding: 0;
  margin: 0;
  text-align: left;
  width: 100%;
  max-width: 640px;
}
.about-codex li {
  display: flex;
  gap: 20px;
  padding: 24px 0;
  border-bottom: 1px solid var(--border);
}
.about-codex li:last-child {
  border-bottom: none;
}
.about-codex__num {
  font-family: 'Michroma', monospace;
  font-size: 13px;
  color: var(--red);
  flex-shrink: 0;
  padding-top: 2px;
}
.about-codex strong {
  display: block;
  font-size: 1rem;
  color: var(--text);
  margin-bottom: 6px;
}
.about-codex p {
  font-size: 0.9rem;
  line-height: 1.65;
  color: var(--text-muted);
  margin: 0;
}

/* ═══ PANEL 3 — PROCESS ═══ */
.about-panel--process {
  background:
    radial-gradient(ellipse 60% 50% at 50% 50%, rgba(220,38,38,0.04) 0%, transparent 70%),
    var(--bg);
}

.about-steps {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 32px;
  width: 100%;
  margin-top: 8px;
}
.about-step {
  text-align: left;
  padding: 28px 24px;
  border: 1px solid var(--border);
  border-radius: 10px;
  background: rgba(255,255,255,0.02);
  transition: border-color 0.3s, background 0.3s;
}
.about-step:hover {
  border-color: rgba(220,38,38,0.25);
  background: rgba(220,38,38,0.04);
}
.about-step__icon {
  font-family: 'Michroma', monospace;
  font-size: 12px;
  color: var(--red);
  display: block;
  margin-bottom: 14px;
}
.about-step h3 {
  font-family: 'Michroma', monospace;
  font-size: 0.85rem;
  color: var(--text);
  margin: 0 0 8px;
  font-weight: 400;
}
.about-step p {
  font-size: 0.85rem;
  line-height: 1.6;
  color: var(--text-muted);
  margin: 0;
}

/* ═══ PANEL 4 — STATS ═══ */
.about-panel--stats {
  background: var(--bg2);
}

.about-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 32px;
  width: 100%;
  max-width: 700px;
  margin-bottom: 40px;
}
.about-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.about-stat__num {
  font-family: 'Michroma', monospace;
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--text);
  line-height: 1;
}
.about-stat__num em {
  color: var(--red);
  font-style: normal;
}
.about-stat__label {
  font-size: 0.8rem;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

.about-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Michroma', monospace;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--red);
  border: 1px solid rgba(220,38,38,0.25);
  border-radius: 999px;
  padding: 10px 22px;
}
.about-badge__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--red);
  box-shadow: 0 0 8px var(--red-glow);
  animation: about-pulse 2s ease-in-out infinite;
}
@keyframes about-pulse {
  0%, 100% { opacity: 1; }
  50%      { opacity: 0.4; }
}

/* ═══ PANEL 5 — CTA ═══ */
.about-panel--cta {
  background:
    radial-gradient(ellipse 70% 50% at 50% 60%, rgba(220,38,38,0.07) 0%, transparent 70%),
    var(--bg);
  min-height: 70vh;
}

.about-cta__heading {
  font-family: 'Michroma', monospace;
  font-size: clamp(1.6rem, 3.5vw, 2.6rem);
  color: var(--text);
  margin: 0 0 16px;
  font-weight: 400;
}
.about-cta__sub {
  font-size: 1rem;
  color: var(--text-muted);
  margin: 0 0 36px;
}

.about-cta__buttons {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  justify-content: center;
}
.about-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Michroma', monospace;
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 14px 32px;
  border-radius: 6px;
  transition: all 0.3s;
}
.about-btn--wa {
  background: var(--red);
  color: #fff;
  border: 1px solid var(--red);
}
.about-btn--wa:hover {
  background: transparent;
  box-shadow: 0 0 20px var(--red-glow);
}
.about-btn--outline {
  background: transparent;
  color: var(--text);
  border: 1px solid var(--border);
}
.about-btn--outline:hover {
  border-color: var(--red);
  color: var(--red);
  box-shadow: 0 0 20px var(--red-glow);
}

/* ═══ RESPONSIVE ═══ */
@media (max-width: 768px) {
  .about-panel__inner {
    padding: 60px 20px;
  }
  .about-steps {
    grid-template-columns: 1fr;
  }
  .about-stats {
    grid-template-columns: repeat(2, 1fr);
  }
}

</style>

<!-- ═══════════════════════════════════════════
     GSAP STACKING PANELS
     ═══════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const STACK_PREFIX = 'about-stack-';

  function initAboutStack() {
    /* ---- cleanup previous run (View Transition) ---- */
    ScrollTrigger.getAll().forEach(st => {
      if (st.vars?.id?.startsWith(STACK_PREFIX)) st.kill(true);
    });

    /* unwrap any leftover .panel-wrap from previous runs */
    document.querySelectorAll<HTMLElement>('.about-stack .panel-wrap').forEach(wrap => {
      const parent = wrap.parentElement;
      if (!parent) return;
      while (wrap.firstChild) parent.insertBefore(wrap.firstChild, wrap);
      wrap.remove();
      parent.style.marginBottom = '';
      parent.style.zIndex = '';
      gsap.set(parent, { clearProps: 'scale,opacity' });
    });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const allPanels = gsap.utils.toArray<HTMLElement>('.about-stack > .about-panel');
    if (allPanels.length < 2) return;

    /* skip last panel (CTA) — it scrolls in normally */
    const panels = allPanels.slice(0, -1);

    panels.forEach((panel, i) => {
      /* wrap panel children so we can fake-scroll them */
      const inner = panel.querySelector<HTMLElement>('.about-panel__inner');
      if (!inner) return;

      panel.style.zIndex = String(i + 1);

      const panelHeight  = inner.offsetHeight;
      const windowHeight = window.innerHeight;
      const difference   = panelHeight - windowHeight;

      const fakeScrollRatio = difference > 0
        ? difference / (difference + windowHeight)
        : 0;

      if (fakeScrollRatio) {
        panel.style.marginBottom = panelHeight * fakeScrollRatio + 'px';
      }

      const tl = gsap.timeline({
        scrollTrigger: {
          id: `${STACK_PREFIX}${i}`,
          trigger: panel,
          start: 'bottom bottom',
          end: () => fakeScrollRatio
            ? `+=${inner.offsetHeight}`
            : 'bottom top',
          pinSpacing: false,
          pin: true,
          scrub: true,
        },
      });

      /* fake-scroll if content is taller than viewport */
      if (fakeScrollRatio) {
        tl.to(inner, {
          yPercent: -100,
          y: windowHeight,
          duration: 1 / (1 - fakeScrollRatio) - 1,
          ease: 'none',
        });
      }

      /* scale down + fade out */
      tl.fromTo(panel,
        { scale: 1, opacity: 1 },
        { scale: 0.7, opacity: 0.5, duration: 0.9 }
      ).to(panel, { opacity: 0, duration: 0.1 });
    });

    /* last panel sits on top */
    const last = allPanels[allPanels.length - 1];
    if (last) last.style.zIndex = String(panels.length + 1);

    ScrollTrigger.refresh();
  }

  function run() {
    requestAnimationFrame(() => {
      requestAnimationFrame(() => initAboutStack());
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run, { once: true });
  } else {
    run();
  }

  document.addEventListener('astro:page-load', run);
  document.addEventListener('astro:after-swap', run);
</script>
