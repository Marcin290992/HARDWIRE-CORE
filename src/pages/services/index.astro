---
import Layout from '../../layouts/Layout.astro';
import SiteMenu from '../../components/SiteMenu.astro';
import Footer from '../../components/Footer.astro';
import { serviceCategories } from '../../data/services';
---

<Layout
  title="Services | Hardwire Core"
  description="Computer repair services in Stanwell TW19, Surrey. Free diagnosis, no fix no fee."
>
  <SiteMenu />

  <main>
    <section class="svc-index__hero" aria-label="Services hero">
      <div class="svc-index__hero-topline" aria-hidden="true"></div>
      <div class="svc-index__hero-inner">
        <span class="svc-index__eyebrow">// All services</span>
        <span class="svc-index__hero-line" aria-hidden="true"></span>
        <h1>What I Fix</h1>
        <p>Every repair starts with a free diagnosis. No fix, no fee.</p>
      </div>
    </section>

    <section class="svc-index__main is-inview" aria-label="Services listing">
      <div class="svc-index__inner">
        <div class="svc-index__categories">
          {serviceCategories.map((category) => (
            <section id={`cat-${category.id}`} class="svc-index__cat">
              <h2>{category.title}</h2>
              <div class="svc-index__grid">
                {category.items.map((item) => (
                  <a href={`/services/${item.slug}/`} class="svc-index__item" aria-label={`View ${item.title}`}>
                    <div class="svc-index__item-img">
                      <img src={item.img} alt="" loading="lazy" decoding="async" />
                      <span class="svc-index__scanline" aria-hidden="true"></span>
                    </div>
                    <div class="svc-index__item-body">
                      <div class="svc-index__item-left">
                        <span class="svc-index__item-title">{item.title}</span>
                        <span class="svc-index__item-time">{item.time}</span>
                      </div>
                      <div class="svc-index__item-right">
                        <span class="svc-index__item-price">{item.price}</span>
                        {item.tag && <span class="svc-index__item-tag">{item.tag}</span>}
                      </div>
                    </div>
                    <span class="svc-index__arrow" aria-hidden="true">-&gt;</span>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style is:inline>
.page-subpage { background: var(--bg); }
.svc-index__hero {
  position: relative;
  background: var(--bg);
  overflow: hidden;
}

.svc-index__hero::before,
.svc-index__main::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.12) 2px, rgba(0, 0, 0, 0.12) 4px);
  pointer-events: none;
  z-index: 0;
}

.svc-index__hero > *,
.svc-index__main > * {
  position: relative;
  z-index: 1;
}

.svc-index__hero-topline {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(220, 38, 38, 0.5), transparent);
}

.svc-index__hero-inner {
  max-width: 1400px;
  min-height: calc(100vh - var(--header-h, 108px));
  margin: 0 auto;
  padding: 4.5rem 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
  align-items: center;
}

.svc-index__eyebrow {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--red);
  text-shadow: 0 0 16px rgba(220, 38, 38, 0.35);
  margin-bottom: 0.75rem;
}

.svc-index__hero-line {
  display: block;
  width: 40px;
  height: 2px;
  background: var(--red);
  margin-bottom: 1rem;
  box-shadow: 0 0 12px rgba(220, 38, 38, 0.4);
}

.svc-index__hero h1 {
  font-family: var(--font-head);
  font-size: clamp(2.2rem, 5vw, 3.6rem);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 0.9rem;
  color: var(--text);
}

.svc-index__hero p {
  font-family: var(--font-body);
  font-size: 1.05rem;
  line-height: 1.7;
  color: var(--text-mid);
  max-width: 44ch;
}

.svc-index__main {
  position: relative;
  background: var(--bg);
  overflow: hidden;
}

.svc-index__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 4rem 2.5rem 6rem;
  display: block;
}

.svc-index__categories {
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

.svc-index__cat h2 {
  margin-bottom: 1.25rem;
  padding-bottom: 0.85rem;
  border-bottom: 1px solid rgba(220, 38, 38, 0.15);
  font-family: var(--font-head);
  font-size: 13px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-muted);
  transition: color 0.25s var(--ease), border-color 0.25s var(--ease);
}

.svc-index__cat {
  border-left: 2px solid transparent;
  padding: 0.25rem 0 0.25rem 1rem;
  transition: border-color 0.2s var(--ease), background 0.2s var(--ease);
}

.svc-index__cat:hover h2 {
  color: var(--text);
  border-bottom-color: rgba(220, 38, 38, 0.35);
}

.svc-index__cat.is-active {
  border-left-color: var(--red);
  background: rgba(220, 38, 38, 0.03);
}

.svc-index__cat.is-active h2 {
  color: var(--text);
  border-bottom-color: rgba(220, 38, 38, 0.3);
}

.svc-index__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 0.85rem;
}

.svc-index__item {
  position: relative;
  display: flex;
  flex-direction: column;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.02);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  border-radius: 2px;
  overflow: hidden;
  transition: border-color 0.25s var(--ease), background 0.25s var(--ease), box-shadow 0.25s var(--ease), transform 0.2s var(--ease);
}

.svc-index__item:hover {
  border-color: rgba(220, 38, 38, 0.35);
  background: rgba(220, 38, 38, 0.04);
  box-shadow: 0 0 24px rgba(220, 38, 38, 0.1), 0 0 0 1px rgba(220, 38, 38, 0.15);
  transform: translateY(-2px);
}

/* ── Image ── */
.svc-index__item-img {
  position: relative;
  width: 100%;
  height: 140px;
  overflow: hidden;
}

.svc-index__item-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  filter: brightness(0.55) saturate(0.7);
  transition: filter 0.35s var(--ease), transform 0.35s var(--ease);
}

.svc-index__item:hover .svc-index__item-img img {
  filter: brightness(0.65) saturate(0.85);
  transform: scale(1.04);
}

/* ── Scanline hover ── */
.svc-index__scanline {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s var(--ease);
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(220, 38, 38, 0.06) 2px,
      rgba(220, 38, 38, 0.06) 4px
    );
}

.svc-index__scanline::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(220, 38, 38, 0.7), transparent);
  box-shadow: 0 0 12px rgba(220, 38, 38, 0.5);
  transform: translateY(-100%);
  animation: none;
}

.svc-index__item:hover .svc-index__scanline {
  opacity: 1;
}

.svc-index__item:hover .svc-index__scanline::after {
  animation: svc-scan 1.8s linear infinite;
}

@keyframes svc-scan {
  0%   { transform: translateY(-4px); }
  100% { transform: translateY(140px); }
}

/* ── Dark vignette on image ── */
.svc-index__item-img::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 40%, rgba(8, 8, 10, 0.85) 100%);
  pointer-events: none;
}

/* ── Body ── */
.svc-index__item-body {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: start;
  gap: 0.75rem;
  padding: 1rem 1.2rem 1.15rem;
}

.svc-index__item-left {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.svc-index__item-title {
  font-family: var(--font-head);
  font-size: 12px;
  letter-spacing: 0.1em;
  line-height: 1.45;
  text-transform: uppercase;
  color: var(--text);
}

.svc-index__item-time {
  font-family: var(--font-mono);
  font-size: 9px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
}

.svc-index__item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.35rem;
}

.svc-index__item-price {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: var(--red);
  text-shadow: 0 0 10px rgba(220, 38, 38, 0.35);
}

.svc-index__item-tag {
  display: inline-flex;
  align-items: center;
  height: 20px;
  padding: 2px 8px;
  border: 1px solid rgba(220, 38, 38, 0.3);
  border-radius: 2px;
  font-family: var(--font-mono);
  font-size: 8px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--red);
  text-shadow: 0 0 8px rgba(220, 38, 38, 0.3);
}

.svc-index__arrow {
  position: absolute;
  right: 1rem;
  bottom: 0.85rem;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--red);
  opacity: 0;
  transition: opacity 0.2s var(--ease), transform 0.2s var(--ease);
  transform: translateX(-4px);
  text-shadow: 0 0 6px rgba(220, 38, 38, 0.5);
}

.svc-index__item:hover .svc-index__arrow {
  opacity: 1;
  transform: translateX(0);
}

@media (max-width: 768px) {
  .svc-index__hero-inner {
    min-height: 240px;
    padding: 3rem 1rem;
  }

  .svc-index__cat {
    padding-left: 0.65rem;
  }

  .svc-index__categories {
    gap: 2.2rem;
  }

  .svc-index__cat h2 {
    font-size: 12px;
  }

  .svc-index__grid {
    grid-template-columns: 1fr;
    gap: 0.6rem;
  }

  .svc-index__item-img {
    height: 110px;
  }

  .svc-index__item-body {
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding: 0.9rem 1rem 1rem;
  }

  .svc-index__item-right {
    align-items: flex-start;
  }

  .svc-index__arrow {
    right: 0.75rem;
    bottom: 0.65rem;
  }

  .svc-index__inner {
    padding-left: 1rem;
    padding-right: 1rem;
  }

  @keyframes svc-scan {
    0%   { transform: translateY(-4px); }
    100% { transform: translateY(110px); }
  }
}
</style>
