---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import '../styles/hardwire.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hardwire Core',
  description = 'Professional computer repair services in Stanwell TW19.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#080808" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<style is:inline>
			:root {
				color-scheme: dark;
			}

			html,
			body {
				min-height: 100%;
				margin: 0;
				background: #0f0f0f;
				color: #f0f0f0;
			}

			body {
				font-family: 'Exo 2', system-ui, sans-serif;
			}
		</style>
		<ClientRouter />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
